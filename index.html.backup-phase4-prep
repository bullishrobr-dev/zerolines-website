        // Animate subtitle and CTA
        var heroSection = heroH1.closest('section');
        if (heroSection) {
          var subtitle = heroSection.querySelector('p.text-body-large, p.text-h1 + p');
          if (subtitle) subtitle.classList.add('zl-hero-subtitle');
          var cta = heroSection.querySelector('.btn-primary, a[href*="protocol"]');
          if (cta) cta.classList.add('zl-hero-cta');
        }

        // Trigger entrance after a brief delay
        setTimeout(function() {
          heroH1.querySelectorAll('.zl-hero-line-inner').forEach(function(el) {
            el.classList.add('is-revealed');
          });
          var sub = document.querySelector('.zl-hero-subtitle');
          if (sub) sub.classList.add('is-revealed');
          var ctaEl = document.querySelector('.zl-hero-cta');
          if (ctaEl) ctaEl.classList.add('is-revealed');
        }, 400);
      }

      // ============================================================
      // 7. CUSTOM CURSOR (DISABLED — user prefers default cursor)
      // ============================================================
      // Custom cursor removed per user request. Default system cursor is active.

      // ============================================================
      // 8. MAGNETIC BUTTONS
      // ============================================================
      function initMagneticButtons() {
        if (isTouch) return;
        var magneticSelectors = '.btn-primary, .text-cta, a[class*="btn"]';
        document.querySelectorAll(magneticSelectors).forEach(function(btn) {
          if (btn.classList.contains('zl-magnetic-initialized')) return;
          btn.classList.add('zl-magnetic', 'zl-magnetic-initialized');

          btn.addEventListener('mousemove', function(e) {
            var rect = btn.getBoundingClientRect();
            var x = e.clientX - rect.left - rect.width / 2;
            var y = e.clientY - rect.top - rect.height / 2;
            btn.style.transform = 'translate(' + (x * 0.25) + 'px, ' + (y * 0.25) + 'px)';
          }, { passive: true });

          btn.addEventListener('mouseleave', function() {
            btn.style.transform = 'translate(0, 0)';
          }, { passive: true });
        });
      }

      // ============================================================
      // 9. PARALLAX HERO
      // ============================================================
      function initParallax() {
        var heroBg = document.querySelector('section img[src*="atmosphere-hero"]');
        if (!heroBg) return;
        var heroSection = heroBg.closest('section');
        if (!heroSection) return;
        heroBg.classList.add('zl-parallax-bg');

        var parallaxTicking = false;
        function updateParallax() {
          var rect = heroSection.getBoundingClientRect();
          var scrollProgress = -rect.top / rect.height;
          if (scrollProgress > -1 && scrollProgress < 2) {
            var yOffset = scrollProgress * 80;
            heroBg.style.transform = 'translateY(' + yOffset + 'px) scale(1.05)';
          }
          parallaxTicking = false;
        }
        window.addEventListener('scroll', function() {
          if (!parallaxTicking) {
            requestAnimationFrame(updateParallax);
            parallaxTicking = true;
          }
        }, { passive: true });
      }

      // ============================================================
      // 10. PAGE TRANSITION WIPE
      // ============================================================
      var pageWipe = document.getElementById('zl-page-wipe');
      function triggerPageTransition(callback) {
        if (!pageWipe) { if (callback) callback(); return; }
        pageWipe.classList.remove('is-exiting');
        pageWipe.classList.add('is-active');
        setTimeout(function() {
          if (callback) callback();
          setTimeout(function() {
            pageWipe.classList.remove('is-active');
            pageWipe.classList.add('is-exiting');
            setTimeout(function() {
              pageWipe.classList.remove('is-exiting');
            }, 600);
          }, 100);
        }, 500);
      }

      // Run after React renders
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          setTimeout(initAnimations, 1500);
          setTimeout(initAnimations, 3000);
        });
      } else {
        setTimeout(initAnimations, 1500);
        setTimeout(initAnimations, 3000);
      }

