    <!-- Lenis Smooth Scroll -->
    <script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js" onerror="window.zlLenisFailed=true"></script>
    <script>
    (function() {
      'use strict';

      // ============================================================
      // 1. SMOOTH SCROLL (Lenis with fallback)
      // ============================================================
      var lenis = null;
      if (typeof Lenis !== 'undefined' && !window.zlLenisFailed) {
        lenis = new Lenis({
          duration: 1.2,
          easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 2,
        });
        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
        window.zlLenis = lenis;
      }

      // ============================================================
      // 2. SCROLL PROGRESS BAR
      // ============================================================
      var progressBar = document.getElementById('zl-scroll-progress');
      function updateProgress() {
        if (!progressBar) return;
        var scrollTop = window.scrollY || document.documentElement.scrollTop;
        var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      // ============================================================
      // 3. NAVBAR HIDE ON SCROLL DOWN / SHOW ON SCROLL UP
      // ============================================================
      var lastScrollY = 0;
      var navHideThreshold = 100;
      var ticking = false;
      function updateNavbar() {
        var currentY = window.scrollY;
        if (currentY < navHideThreshold) {
          document.body.classList.remove('nav-is-hiding');
          document.body.classList.add('nav-is-showing');
        } else if (currentY > lastScrollY && currentY > navHideThreshold) {
          // Scrolling down
          document.body.classList.add('nav-is-hiding');
          document.body.classList.remove('nav-is-showing');
        } else if (currentY < lastScrollY) {
          // Scrolling up
          document.body.classList.remove('nav-is-hiding');
          document.body.classList.add('nav-is-showing');
        }
        lastScrollY = currentY;
        ticking = false;
      }
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(updateNavbar);
          ticking = true;
        }
      }, { passive: true });
      document.body.classList.add('nav-is-showing');

      // ============================================================
      // 4. INTERSECTION OBSERVER — REVEAL ANIMATIONS
      // ============================================================
      var revealObserver = null;
      function initRevealObserver() {
        if (revealObserver) revealObserver.disconnect();
        revealObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              // Optionally unobserve after first reveal:
              // revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

        // Observe image reveal containers
        document.querySelectorAll('.zl-reveal-img').forEach(function(el) {
          revealObserver.observe(el);
        });
        // Observe text reveal containers
        document.querySelectorAll('.zl-reveal-text').forEach(function(el) {
          revealObserver.observe(el);
        });
        // Observe fade-up elements
        document.querySelectorAll('.zl-fade-up').forEach(function(el) {
          revealObserver.observe(el);
        });
      }

      // ============================================================
      // 5. IMAGE REVEAL AUTO-WRAPPER
      // ============================================================
      function wrapImagesForReveal() {
        // Wrap images that look like they should reveal
        var selectors = [
          'section img[src*="product-"]',
          'section img[src*="hero-"]',
          'section img[src*="editorial"]',
          '.content-max-width img',
          '[class*="grid"] img'
        ];
        selectors.forEach(function(sel) {
          document.querySelectorAll(sel).forEach(function(img) {
            if (img.closest('.zl-reveal-img')) return; // already wrapped
            if (img.width < 100) return; // skip tiny icons
            var parent = img.parentElement;
            if (!parent) return;
            // Create wrapper
            var wrapper = document.createElement('div');
            wrapper.className = 'zl-reveal-img';
            parent.insertBefore(wrapper, img);
            wrapper.appendChild(img);
          });
        });
      }

      // ============================================================
      // 6. TEXT REVEAL AUTO-WRAPPER (LINE-GROUPED)
      // ============================================================
      function wrapTextForReveal() {
        var allHeadings = document.querySelectorAll('h2.text-h2, h2.font-serif, h3.text-h3');
        allHeadings.forEach(function(h) {
          if (h.closest('.zl-reveal-text')) return;
          if (!h.textContent.trim()) return;
          if (h.textContent.trim().split(/\s+/).length < 2) return;

          // Use line-by-line grouping for cleaner editorial effect
          var originalText = h.textContent.trim();
          var words = originalText.split(/\s+/);
          h.innerHTML = '';
          h.style.opacity = '1'; // ensure visible for measurement

          // First pass: wrap all words in inline spans to measure lines
          var tempSpans = [];
          words.forEach(function(word) {
            var span = document.createElement('span');
            span.style.display = 'inline-block';
            span.style.whiteSpace = 'nowrap';
            span.textContent = word + '\u00A0';
            h.appendChild(span);
            tempSpans.push(span);
          });

          // Measure which words fall on which lines
          var lines = [];
          var currentLine = [];
          var lastTop = null;
          tempSpans.forEach(function(span) {
            var rect = span.getBoundingClientRect();
            if (lastTop !== null && Math.abs(rect.top - lastTop) > 3) {
              lines.push(currentLine);
              currentLine = [];
            }
            currentLine.push(span.textContent.trim());
            lastTop = rect.top;
          });
          if (currentLine.length) lines.push(currentLine);

          // Second pass: rebuild with line wrappers
          h.innerHTML = '';
          lines.forEach(function(lineWords) {
            var lineDiv = document.createElement('span');
            lineDiv.className = 'zl-line';
            var lineInner = document.createElement('span');
            lineInner.className = 'zl-line-inner';
            lineInner.textContent = lineWords.join(' ');
            lineDiv.appendChild(lineInner);
            h.appendChild(lineDiv);
          });

          h.classList.add('zl-reveal-text');
        });
      }

      // ============================================================
      // 6b. HERO ENTRANCE ANIMATION
      // ============================================================
      function initHeroEntrance() {
        // Only on homepage
        if (!document.body.classList.contains('homepage')) return;
        // Find hero h1
        var heroH1 = document.querySelector('section h1.text-h1, section h1.font-serif, section h1');
        if (!heroH1 || heroH1.closest('.zl-hero-entrance')) return;

        var text = heroH1.textContent.trim();
        if (!text) return;

        // Split into words and measure lines
        var words = text.split(/\s+/);
        heroH1.innerHTML = '';
        heroH1.classList.add('zl-hero-entrance');

        var tempSpans = [];
        words.forEach(function(word) {
          var span = document.createElement('span');
          span.style.display = 'inline-block';
          span.style.whiteSpace = 'nowrap';
          span.textContent = word + '\u00A0';
          heroH1.appendChild(span);
          tempSpans.push(span);
        });

        var lines = [];
        var currentLine = [];
        var lastTop = null;
        tempSpans.forEach(function(span) {
          var rect = span.getBoundingClientRect();
          if (lastTop !== null && Math.abs(rect.top - lastTop) > 3) {
            lines.push(currentLine);
            currentLine = [];
          }
          currentLine.push(span.textContent.trim());
          lastTop = rect.top;
        });
        if (currentLine.length) lines.push(currentLine);

        heroH1.innerHTML = '';
        lines.forEach(function(lineWords) {
          var lineWrap = document.createElement('span');
          lineWrap.className = 'zl-hero-line';
          var lineInner = document.createElement('span');
          lineInner.className = 'zl-hero-line-inner';
          lineInner.textContent = lineWords.join(' ');
          lineWrap.appendChild(lineInner);
          heroH1.appendChild(lineWrap);
