            { flag: '🇦🇩', city: 'Andorra', street: 'Av. Meritxell, 47, AD500 Andorra la Vella' },
            { flag: '🇪🇸', city: 'Marbella, Spain', street: 'Local 2, C. Misericordia, 6, 29601 Marbella, Málaga' }
          ];

          addresses.forEach(function(addr) {
            var card = document.createElement('div');
            card.className = 'zl-contact-address';
            card.innerHTML = '<span class="zl-contact-address-flag">' + addr.flag + '</span>' +
              '<div class="zl-contact-address-city">' + addr.city + '</div>' +
              '<p class="zl-contact-address-street">' + addr.street + '</p>';
            addrGrid.appendChild(card);
          });

          visitSection.appendChild(addrGrid);
        }
      }

      // ============================================================
      // 13. 3D PRODUCT CARD TILT
      // ============================================================
      function init3DCardTilt() {
        if (isTouch) return;
        var cards = document.querySelectorAll('[class*="grid"] > a, [class*="grid"] > article, .product-card');
        cards.forEach(function(card) {
          if (card.classList.contains('zl-tilt-initialized')) return;
          card.classList.add('zl-tilt-initialized', 'zl-tilt-card');
          card.style.position = 'relative';

          var shine = document.createElement('div');
          shine.className = 'zl-tilt-shine';
          card.appendChild(shine);

          card.addEventListener('mousemove', function(e) {
            var rect = card.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            var centerX = rect.width / 2;
            var centerY = rect.height / 2;
            var rotateX = ((y - centerY) / centerY) * -8;
            var rotateY = ((x - centerX) / centerX) * 8;
            card.style.transform = 'perspective(1000px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) translateZ(10px)';
            shine.style.background = 'linear-gradient(' + (Math.atan2(y - centerY, x - centerX) * 180 / Math.PI + 90) + 'deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0) 100%)';
          }, { passive: true });

          card.addEventListener('mouseleave', function() {
            card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) translateZ(0)';
          }, { passive: true });
        });
      }

      // ============================================================
      // 14. CUSTOM CURSOR TEXT LABELS (DISABLED with cursor)
      // ============================================================
      function initCursorLabels() {
        // Disabled per user request — default cursor preferred
      }

      // ============================================================
      // 15. BUTTON RIPPLE EFFECT
      // ============================================================
      function initButtonRipple() {
        document.addEventListener('click', function(e) {
          var btn = e.target.closest('.btn-primary, button[type="submit"]');
          if (!btn) return;

          var ripple = document.createElement('span');
          ripple.style.position = 'absolute';
          ripple.style.borderRadius = '50%';
          ripple.style.background = 'rgba(255,255,255,0.3)';
          ripple.style.transform = 'scale(0)';
          ripple.style.animation = 'zl-ripple 0.6s ease-out';
          ripple.style.pointerEvents = 'none';

          var rect = btn.getBoundingClientRect();
          var size = Math.max(rect.width, rect.height) * 2;
          ripple.style.width = ripple.style.height = size + 'px';
          ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
          ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';

          btn.style.position = 'relative';
          btn.style.overflow = 'hidden';
          btn.appendChild(ripple);

          setTimeout(function() {
            ripple.remove();
          }, 600);
        });
      }

      // ============================================================
      // 16. MOBILE HERO FIX
      // ============================================================
      function fixHeroMobile() {
        if (window.innerWidth > 768) return;
        var heroImg = document.querySelector('section img[src*="atmosphere-hero"]');
        if (heroImg) {
          heroImg.style.objectPosition = 'center 25%';
          var container = heroImg.parentElement;
          if (container) {
            container.style.height = '100%';
            container.style.top = '0';
          }
        }
      }

      // ============================================================
      // 17. INITIALIZATION
      // ============================================================
      function initAnimations() {
        wrapImagesForReveal();
        wrapTextForReveal();
        initRevealObserver();
        initMagneticButtons();
        initParallax();
        initHeroEntrance();
        enhanceContactPage();
        init3DCardTilt();
        initCursorLabels();
        initButtonRipple();
        fixHeroMobile();
      }

      // Re-init on hash change (SPA navigation) with page transition
      window.addEventListener('hashchange', function(e) {
        triggerPageTransition(function() {
          window.scrollTo(0, 0);
        });
        setTimeout(initAnimations, 900);
        setTimeout(initAnimations, 2200);
      });

    })();
    </script>
