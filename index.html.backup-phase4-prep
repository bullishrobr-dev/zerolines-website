    <!-- Page type & scroll state for CSS selectors -->
    <script>
      (function() {
        function getRoute() {
          var hash = window.location.hash || '';
          var path = window.location.pathname || '';
          // Hash router: route is in hash; pathname is always '/'
          if (hash && hash !== '#' && hash !== '#/') {
            return hash.replace(/^#/, '');
          }
          return path;
        }
        function isHomepage() {
          var route = getRoute();
          return route === '/' || route === '' || route === '/index.html' || route === '#/index.html';
        }
        function updateBodyClass() {
          var home = isHomepage();
          if (home) {
            document.body.classList.add('homepage');
            document.body.classList.remove('inner-page');
          } else {
            document.body.classList.add('inner-page');
            document.body.classList.remove('homepage');
            document.body.classList.remove('scrolled');
          }
        }
        updateBodyClass();
        window.addEventListener('hashchange', updateBodyClass);
        // Also watch for pathname changes (unlikely with hash router but safe)
        var lastRoute = getRoute();
        setInterval(function() {
          var current = getRoute();
          if (current !== lastRoute) {
            lastRoute = current;
            updateBodyClass();
          }
        }, 300);
        // Scroll handler for homepage
        function onScroll() {
          if (isHomepage()) {
            if (window.scrollY > 80) {
              document.body.classList.add('scrolled');
            } else {
              document.body.classList.remove('scrolled');
            }
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <!-- Protocol Step Background Images — Product Pages Only -->
    <script>
      (function() {
        if (!window.location.pathname.startsWith('/products/')) return;
        function addProtocolBackgrounds() {
          var stepImages = {
            '01': '/assets/product-peeling.jpg',
            '02': '/assets/product-syringe-hero.jpg',
            '03': '/assets/product-serum.jpg',
            '04': '/assets/product-day-cream.jpg',
            '05': '/assets/product-night-cream.jpg',
            '06': '/assets/product-syringe.jpg',
            '1': '/assets/product-peeling.jpg',
            '2': '/assets/product-syringe-hero.jpg',
            '3': '/assets/product-serum.jpg',
            '4': '/assets/product-day-cream.jpg',
            '5': '/assets/product-night-cream.jpg',
            '6': '/assets/product-syringe.jpg',
          };
          var protocolHeading = Array.from(document.querySelectorAll('h2, h3, h4, p, div, span'))
            .find(function(el) { return /step\s*\d+\s*of\s*6/i.test(el.textContent) || /you are at step/i.test(el.textContent); });
          if (!protocolHeading) return;
          var section = protocolHeading.parentElement;
          for (var i = 0; i < 6; i++) {
            if (!section) break;
            if (section.querySelectorAll('a, div, article').length >= 6) break;
            section = section.parentElement;
          }
          if (!section) section = document.body;
          var candidates = Array.from(section.querySelectorAll('a, div, article'))
            .filter(function(el) {
              var text = el.textContent;
              return (/(^|\s)0?[1-6](\s|$|·)/.test(text) || /^\s*[1-6]\s*·/.test(text) || /^\s*[1-6]\s*$/.test(text.trim()))
                && el.children.length >= 1
                && el.offsetHeight > 60
                && el.offsetHeight < 400;
            });
          var cards = candidates.slice(0, 6);
          if (cards.length !== 6) return;
          cards.forEach(function(card) {
            if (card.querySelector('img[data-protocol-bg]')) return;
            var text = card.textContent;
            var imgSrc = null;
            for (var num in stepImages) {
              var regex = new RegExp('\\b0?' + num + '\\b');
              if (regex.test(text)) { imgSrc = stepImages[num]; break; }
            }
            if (!imgSrc) return;
            var img = document.createElement('img');
            img.src = imgSrc;
            img.setAttribute('data-protocol-bg', 'true');
            img.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.15;pointer-events:none;z-index:0;border-radius:inherit;';
            card.style.position = 'relative';
            card.style.overflow = 'hidden';
            card.insertBefore(img, card.firstChild);
            Array.from(card.children).forEach(function(child) {
              if (child !== img && !child.hasAttribute('data-protocol-bg')) {
                var current = window.getComputedStyle(child).position;
                if (current === 'static') child.style.position = 'relative';
                child.style.zIndex = '1';
              }
            });
          });
        }
        setTimeout(addProtocolBackgrounds, 1500);
        setTimeout(addProtocolBackgrounds, 3000);
      })();
    </script>

