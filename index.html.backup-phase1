    <!-- ===== ZERO LINES ANIMATION SYSTEM ===== -->
    <div id="zl-scroll-progress"></div>
    <div id="zl-cursor" class="zl-cursor"></div>

    <!-- Lenis Smooth Scroll -->
    <script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js" onerror="window.zlLenisFailed=true"></script>
    <script>
    (function() {
      'use strict';

      // ============================================================
      // 1. SMOOTH SCROLL (Lenis with fallback)
      // ============================================================
      var lenis = null;
      if (typeof Lenis !== 'undefined' && !window.zlLenisFailed) {
        lenis = new Lenis({
          duration: 1.2,
          easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 2,
        });
        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
        window.zlLenis = lenis;
      }

      // ============================================================
      // 2. SCROLL PROGRESS BAR
      // ============================================================
      var progressBar = document.getElementById('zl-scroll-progress');
      function updateProgress() {
        if (!progressBar) return;
        var scrollTop = window.scrollY || document.documentElement.scrollTop;
        var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      // ============================================================
      // 3. NAVBAR HIDE ON SCROLL DOWN / SHOW ON SCROLL UP
      // ============================================================
      var lastScrollY = 0;
      var navHideThreshold = 100;
      var ticking = false;
      function updateNavbar() {
        var currentY = window.scrollY;
        if (currentY < navHideThreshold) {
          document.body.classList.remove('nav-is-hiding');
          document.body.classList.add('nav-is-showing');
        } else if (currentY > lastScrollY && currentY > navHideThreshold) {
          // Scrolling down
          document.body.classList.add('nav-is-hiding');
          document.body.classList.remove('nav-is-showing');
        } else if (currentY < lastScrollY) {
          // Scrolling up
          document.body.classList.remove('nav-is-hiding');
          document.body.classList.add('nav-is-showing');
        }
        lastScrollY = currentY;
        ticking = false;
      }
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(updateNavbar);
          ticking = true;
        }
      }, { passive: true });
      document.body.classList.add('nav-is-showing');

      // ============================================================
      // 4. INTERSECTION OBSERVER — REVEAL ANIMATIONS
      // ============================================================
      var revealObserver = null;
      function initRevealObserver() {
        if (revealObserver) revealObserver.disconnect();
        revealObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              // Optionally unobserve after first reveal:
              // revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

        // Observe image reveal containers
        document.querySelectorAll('.zl-reveal-img').forEach(function(el) {
          revealObserver.observe(el);
        });
        // Observe text reveal containers
        document.querySelectorAll('.zl-reveal-text').forEach(function(el) {
          revealObserver.observe(el);
        });
        // Observe fade-up elements
        document.querySelectorAll('.zl-fade-up').forEach(function(el) {
          revealObserver.observe(el);
        });
      }

      // ============================================================
      // 5. IMAGE REVEAL AUTO-WRAPPER
      // ============================================================
      function wrapImagesForReveal() {
        // Wrap images that look like they should reveal
        var selectors = [
          'section img[src*="product-"]',
          'section img[src*="hero-"]',
          'section img[src*="editorial"]',
          '.content-max-width img',
          '[class*="grid"] img'
        ];
        selectors.forEach(function(sel) {
          document.querySelectorAll(sel).forEach(function(img) {
            if (img.closest('.zl-reveal-img')) return; // already wrapped
            if (img.width < 100) return; // skip tiny icons
            var parent = img.parentElement;
            if (!parent) return;
            // Create wrapper
            var wrapper = document.createElement('div');
            wrapper.className = 'zl-reveal-img';
            parent.insertBefore(wrapper, img);
            wrapper.appendChild(img);
          });
        });
      }

      // ============================================================
      // 6. TEXT REVEAL AUTO-WRAPPER
      // ============================================================
      function wrapTextForReveal() {
        // Wrap major headings for word-by-word reveal
        // Skip hero H1 (first h1 in hero section) — too large for word splitting
        var allHeadings = document.querySelectorAll('h2.text-h2, h2.font-serif, h3.text-h3');
        allHeadings.forEach(function(h) {
          if (h.closest('.zl-reveal-text')) return;
          if (!h.textContent.trim()) return;
          // Skip very short headings
          if (h.textContent.trim().split(/\s+/).length < 2) return;
          var words = h.textContent.trim().split(/\s+/);
          h.innerHTML = '';
          words.forEach(function(word, i) {
            var span = document.createElement('span');
            span.className = 'word';
            span.style.display = 'inline-block';
            span.style.overflow = 'hidden';
            span.style.verticalAlign = 'bottom';
            span.style.marginRight = '0.25em';
            var inner = document.createElement('span');
            inner.className = 'word-inner';
            inner.style.display = 'inline-block';
            inner.textContent = word;
            span.appendChild(inner);
            h.appendChild(span);
          });
          h.classList.add('zl-reveal-text');
        });
      }

      // ============================================================
      // 7. CUSTOM CURSOR
      // ============================================================
      var cursor = document.getElementById('zl-cursor');
      var cursorX = 0, cursorY = 0;
      var targetX = 0, targetY = 0;
      var isTouch = window.matchMedia('(pointer: coarse)').matches;

      if (cursor && !isTouch) {
        document.body.classList.add('has-custom-cursor');
        document.addEventListener('mousemove', function(e) {
          targetX = e.clientX;
          targetY = e.clientY;
          if (!cursor.classList.contains('is-active')) {
            cursor.classList.add('is-active');
          }
        }, { passive: true });

        function animateCursor() {
          cursorX += (targetX - cursorX) * 0.15;
          cursorY += (targetY - cursorY) * 0.15;
          cursor.style.left = cursorX + 'px';
          cursor.style.top = cursorY + 'px';
          requestAnimationFrame(animateCursor);
        }
        animateCursor();

        // Hover detection
        var hoverTargets = 'a, button, [role="button"], input, textarea, select, label, .zl-magnetic';
        document.addEventListener('mouseover', function(e) {
          if (e.target.closest(hoverTargets)) {
            cursor.classList.add('is-hovering');
          }
        }, { passive: true });
        document.addEventListener('mouseout', function(e) {
          if (e.target.closest(hoverTargets)) {
            cursor.classList.remove('is-hovering');
          }
        }, { passive: true });

        // Hide cursor when leaving window
        document.addEventListener('mouseleave', function() {
          cursor.classList.remove('is-active');
        });
        document.addEventListener('mouseenter', function() {
          cursor.classList.add('is-active');
        });
      }

      // ============================================================
      // 8. MAGNETIC BUTTONS
      // ============================================================
      function initMagneticButtons() {
        if (isTouch) return;
        var magneticSelectors = '.btn-primary, .text-cta, a[class*="btn"]';
        document.querySelectorAll(magneticSelectors).forEach(function(btn) {
          if (btn.classList.contains('zl-magnetic-initialized')) return;
          btn.classList.add('zl-magnetic', 'zl-magnetic-initialized');

          btn.addEventListener('mousemove', function(e) {
            var rect = btn.getBoundingClientRect();
            var x = e.clientX - rect.left - rect.width / 2;
            var y = e.clientY - rect.top - rect.height / 2;
            btn.style.transform = 'translate(' + (x * 0.25) + 'px, ' + (y * 0.25) + 'px)';
          }, { passive: true });

          btn.addEventListener('mouseleave', function() {
            btn.style.transform = 'translate(0, 0)';
          }, { passive: true });
        });
      }

      // ============================================================
      // 9. PARALLAX HERO
      // ============================================================
      function initParallax() {
        var heroBg = document.querySelector('section img[src*="atmosphere-hero"]');
        if (!heroBg) return;
        var heroSection = heroBg.closest('section');
        if (!heroSection) return;
        heroBg.classList.add('zl-parallax-bg');

        var parallaxTicking = false;
        function updateParallax() {
          var rect = heroSection.getBoundingClientRect();
          var scrollProgress = -rect.top / rect.height;
          if (scrollProgress > -1 && scrollProgress < 2) {
            var yOffset = scrollProgress * 80;
            heroBg.style.transform = 'translateY(' + yOffset + 'px) scale(1.05)';
          }
          parallaxTicking = false;
        }
        window.addEventListener('scroll', function() {
          if (!parallaxTicking) {
            requestAnimationFrame(updateParallax);
            parallaxTicking = true;
          }
        }, { passive: true });
      }

      // ============================================================
      // 10. INITIALIZATION
      // ============================================================
      function initAnimations() {
        wrapImagesForReveal();
        wrapTextForReveal();
        initRevealObserver();
        initMagneticButtons();
        initParallax();
      }

      // Run after React renders
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          setTimeout(initAnimations, 1500);
          setTimeout(initAnimations, 3000);
        });
      } else {
        setTimeout(initAnimations, 1500);
        setTimeout(initAnimations, 3000);
      }

      // Re-init on hash change (SPA navigation)
      window.addEventListener('hashchange', function() {
        setTimeout(initAnimations, 800);
        setTimeout(initAnimations, 2000);
      });

    })();
    </script>
